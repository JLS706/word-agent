from tools.base import Tool


class CustomTool(Tool):
    """自定义工具: add_numbers"""

    name = "add_numbers"
    description = """计算两个数字之和的工具"""
    parameters = {
        "a": {
                "description": "第一个数字",
                "type": "number"
        },
        "b": {
                "description": "第二个数字",
                "type": "number"
        }
}

    def execute(self, **kwargs) -> str:
        def add(a, b):
            return a + b
