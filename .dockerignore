# ──────────────────────────────────────────────
# .dockerignore — 告诉 Docker "不要复制这些文件到镜像里"
# 作用类似 .gitignore，减小镜像体积，避免泄露敏感信息
# ──────────────────────────────────────────────

# Git 版本控制文件（镜像里不需要）
.git
.gitignore

# Python 缓存（镜像里重新生成）
__pycache__
*.pyc
*.pyo

# 虚拟环境（容器有自己的 Python 环境）
venv/
.venv/

# 配置文件（包含 API Key，不能打包进镜像！）
config/config.toml

# 记忆/历史文件（每个容器应该是干净的）
memory/

# 测试文件（生产环境不需要）
test_*.py

# Word 文档（用户的文件不应该打包进镜像）
*.docx
